{
  "name": "text-to-speech-virtual-mic",
  "version": "1.0.0",
  "description": "Floating macOS text-to-speech app that targets a BlackHole virtual microphone.",
  "main": "desktop/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "desktop": "electron .",
    "icons": "node scripts/generate-icons.js",
    "build:helper:macos": "node scripts/build-macos-helper.js",
    "build": "electron-builder --mac",
    "build:win": "node scripts/verify-windows-bundle.js && electron-builder --win nsis zip",
    "list:outputs": "node app.js --list-outputs",
    "list:voices": "node app.js --list-voices",
    "doctor": "node app.js --doctor",
    "setup": "node app.js --setup",
    "stage:blackhole": "node scripts/stage-blackhole.js",
    "stage:vbcable": "node scripts/stage-vbcable.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.afa.desktop",
    "productName": "AFA",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "build/icon.png",
      "desktop/**/*",
      "lib/**/*",
      "resources/**/*",
      "app.js",
      "package.json",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "resources/blackhole",
        "to": "blackhole",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/vbcable",
        "to": "vbcable",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      },
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    }
  },
  "license": "MIT"
}
